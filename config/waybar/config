{
  "layer": "top",
  "height": 37,
  "spacing": 5,
  "modules-left": [
    "image",
    "niri/workspaces",
    "custom/spotify"
  ],
  "modules-center": [
    "user"
  ],
  "modules-right": [
    "tray",
    "bluetooth",
    "power-profiles-daemon",
    "pulseaudio",
    "network",
    "battery",
    "clock",
    "custom/notification",
    "custom/power"
  ],
  "hyprland/window": {
    "separate-outputs": false
  },
  "niri/workspaces": {
    "all-outputs": false,
    "current-only": false
  },
  "user": {
    "format": "  max | ({work_H}hr {work_M} mins тЖС)",
    "interval": 60,
    "height": 23,
    "width": 23,
    "icon": true,
    "avatar": "/home/max/.face.icon"
  },
  "tray": {
    "spacing": 10
  },
  "clock": {
    "format": "{:%H:%M ґ░Гн %a %d}",
    "format-alt": "{:%H:%M яД│ %b %Y}",
    "tooltip-format": "<tt><big>{calendar}</big></tt>"
  },
  "battery": {
    "states": {
      "good": 95,
      "warning": 30,
      "critical": 20
    },
    "format": "{icon} {capacity}%",
    "format-charging": "яЗж {capacity}%",
    "format-plugged": "яЗж {capacity}%",
    "format-alt": "{time} {icon}",
    "format-icons": [
      "ґ░ВО",
      "ґ░Б║",
      "ґ░Б╗",
      "ґ░Б╝",
      "ґ░Б╜",
      "ґ░Б╛",
      "ґ░Б┐",
      "ґ░ВА",
      "ґ░ВБ",
      "ґ░ВВ",
      "ґ░Б╣"
    ]
  },
  "network": {
    "format-wifi": "{ipaddr}",
    "format-ethernet": "яГБ",
    "format-disconnected": "яБ▓",
    "tooltip-format": "Connected to {essid}",
    "tooltip-format-ethernet": "{ifname} яГБ",
    "on-click": "hyprctl dispatch exec '[float]' '$TERMINAL -e nmtui'"
  },
  "pulseaudio": {
    "format": "{icon} {volume}",
    "format-muted": "ґ░ЦБ",
    "on-click": "pavucontrol -t 3",
    "on-click-middle": "volumecontrol.sh -o m",
    "on-scroll-up": "volumecontrol.sh -o i",
    "on-scroll-down": "volumecontrol.sh -o d",
    "tooltip-format": "{icon} {desc} // {volume}%",
    "scroll-step": 5,
    "format-icons": {
      "headphone": "яАе",
      "hands-free": "яАе",
      "headset": "яАе",
      "phone": "яВХ",
      "portable": "яВХ",
      "car": "яЖ╣",
      "default": [
        "яАж",
        "яАз",
        "яАи"
      ]
    }
  },
  "pulseaudio#microphone": {
    "format": "{format_source}",
    "format-source": "ґ░Нм",
    "format-source-muted": "яД▒",
    "on-click": "pavucontrol -t 4",
    "on-click-middle": "volumecontrol.sh -i m",
    "on-scroll-up": "volumecontrol.sh -i i",
    "on-scroll-down": "volumecontrol.sh -i d",
    "tooltip-format": "{format_source} {source_desc} // {source_volume}%",
    "scroll-step": 5
  },
  "custom/power": {
    "format": "яАС{}",
    "exec": "echo ; echo яАС logout",
    "on-click": "wlogout-launcher-hyprland 1",
    "interval": 86400,
    "tooltip": true
  },
  "power-profiles-daemon": {
    "format": "{icon}",
    "tooltip-format": "Power profile: {profile}\nDriver: {driver}",
    "tooltip": true,
    "format-icons": {
      "default": "яГз",
      "performance": "яГз",
      "balanced": "яЙО",
      "power-saver": "яБм"
    }
  },
  "image": {
    "path": "/home/max/.config/waybar/nix.svg",
    "size": 20,
    "interval": 5,
    "on-click": "brave https://search.nixos.org/packages"
  },
  "bluetooth": {
    "format": "ґ░Вп",
    "format-disabled": "ґ░В▓",
    "format-connected": "ґ░В▒",
    "tooltip-format": "{controller_alias}\t{controller_address}",
    "tooltip-format-connected": "{controller_alias}\t{controller_address}\n\n{device_enumerate}",
    "tooltip-format-enumerate-connected": "{device_alias}\t{device_address}",
    "on-click": "blueman-manager"
  },
  "custom/spotify": {
    "exec": "/usr/bin/python3 $HOME/.config/waybar/modules/mediaplayer.py --player spotify",
    "format": "{} яЖ╝",
    "return-type": "json",
    "on-click": "playerctl play-pause --player spotify",
    "on-scroll-up": "playerctl next",
    "on-scroll-down": "playerctl previous"
  },
  "custom/notification": {
    "tooltip": false,
    "format": "{icon}",
    "format-icons": {
      "notification": "яВв<span foreground='red'><sup>яСД</sup></span>",
      "none": "яВв",
      "dnd-notification": "яЗ╖<span foreground='red'><sup>яСД</sup></span>",
      "dnd-none": "яЗ╖",
      "inhibited-notification": "яВв<span foreground='red'><sup>яСД</sup></span>",
      "inhibited-none": "яВв",
      "dnd-inhibited-notification": "яЗ╖<span foreground='red'><sup>яСД</sup></span>",
      "dnd-inhibited-none": "яЗ╖"
    },
    "return-type": "json",
    "exec-if": "which swaync-client",
    "exec": "swaync-client -swb",
    "on-click": "swaync-client -t -sw",
    "on-click-right": "swaync-client -d -sw",
    "escape": true
  },
  "custom/weather": {
    "exec": "~/.config/scripts/weather",
    "interval": 3600,
    "format": "{}",
    "return-type": "text"
  }
}
